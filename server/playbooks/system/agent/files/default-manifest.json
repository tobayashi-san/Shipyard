{
  "_comment": [
    "Agent manifest — edit here, agents auto-fetch on next cycle.",
    "version: bump on every change. interval: seconds between cycles."
  ],

  "version": 1,
  "interval": 30,

  "collectors": [
    {
      "id": "cpu",
      "description": "CPU usage from /proc/stat",
      "cmd": "head -1 /proc/stat",
      "timeout": 3,
      "parser": "cpu_stat"
    },
    {
      "id": "memory",
      "description": "RAM info from /proc/meminfo",
      "cmd": "grep -E '^(MemTotal|MemAvailable|MemFree|Buffers|Cached|SwapTotal|SwapFree):' /proc/meminfo",
      "timeout": 3,
      "parser": "meminfo"
    },
    {
      "id": "disk",
      "description": "Disk usage of mounted partitions",
      "cmd": "df -BM -x tmpfs -x devtmpfs -x overlay",
      "timeout": 5,
      "parser": "df"
    },
    {
      "id": "load",
      "description": "Load average",
      "cmd": "cat /proc/loadavg",
      "timeout": 3,
      "parser": "loadavg"
    },
    {
      "id": "uptime",
      "description": "Uptime in seconds",
      "cmd": "awk '{print $1}' /proc/uptime",
      "timeout": 3,
      "parser": "raw_number"
    },
    {
      "id": "network",
      "description": "Network interfaces RX/TX bytes",
      "cmd": "cat /proc/net/dev",
      "timeout": 3,
      "parser": "proc_net_dev"
    },
    {
      "id": "docker_ps",
      "description": "Running Docker containers (silent fail without Docker)",
      "cmd": "docker ps --format '{{.ID}}\\t{{.Names}}\\t{{.Status}}\\t{{.Image}}' 2>/dev/null",
      "timeout": 5,
      "parser": "docker_ps"
    },
    {
      "id": "os_info",
      "description": "OS release info",
      "cmd": "cat /etc/os-release",
      "timeout": 3,
      "parser": "key_value"
    },
    {
      "id": "nproc",
      "description": "CPU core count",
      "cmd": "nproc",
      "timeout": 3,
      "parser": "raw_number"
    }
  ]
}
